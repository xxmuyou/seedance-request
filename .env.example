# Core
SEED_PROVIDER=seedream
SEED_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEED_API_KEY=xxxx
SEED_TIMEOUT_MS=300000
SEED_POLL_INTERVAL_MS=10000
SEED_POLL_MAX_ATTEMPTS=30
SEED_EXTRA_HEADERS={}
SEED_ASSETS_DIR=assets

# Per-provider output directories (optional, fallback to SEED_ASSETS_DIR)
SEEDREAM_ASSETS_DIR=assets/seedream/Terra
SEEDANCE_ASSETS_DIR=assets/seedance/Terra
SEED3D_ASSETS_DIR=assets/seed3d/Terra

# Seedream defaults
SEEDREAM_MODEL=doubao-seedream-5-0-260128
SEEDREAM_PATH=/images/generations
SEEDREAM_SIZE=2K
SEEDREAM_IMAGE=
SEEDREAM_OUTPUT_FORMAT=png
SEEDREAM_WATERMARK=false
# 多图生成时使用（传入多张 --image 时自动启用）
SEEDREAM_SEQUENTIAL_IMAGE_GENERATION=auto
SEEDREAM_MAX_IMAGES=3

# Seedance defaults
SEEDANCE_MODEL=doubao-seedance-1-5-pro-251215
SEEDANCE_CREATE_PATH=/contents/generations/tasks
SEEDANCE_STATUS_PATH=/contents/generations/tasks/{id}
SEEDANCE_IMAGE_URL=
SEEDANCE_GENERATE_AUDIO=true
SEEDANCE_RATIO=adaptive
SEEDANCE_DURATION=5
SEEDANCE_WATERMARK=false
